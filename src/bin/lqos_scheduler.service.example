[Unit]
Wants=network-online.target
After=network-online.target systemd-resolved.service lqosd.service
Requires=lqosd.service

[Service]
WorkingDirectory=/opt/libreqos/src
ExecStartPre=/bin/test -x /opt/libreqos/venv/bin/python
ExecStartPre=/opt/libreqos/venv/bin/python -c "import apscheduler, chardet, deepdiff, psutil, requests"
ExecStart=/opt/libreqos/venv/bin/python /opt/libreqos/src/scheduler.py
Restart=always

[Install]
WantedBy=default.target
